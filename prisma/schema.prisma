generator client {
  provider = "prisma-client"
  // Moving the client into src makes it visible to your build tools (Vite/TS/etc.)
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // We leave the URL out; it's injected via the config and adapter
}

/**
 * This is NOT an auth table.
 * This is an ownership table.
 * It answers:
 * "who owns the job applications?"
 */

model User {
  id       String @id @default(cuid())
  googleId String @unique

  // Contact info
  email      String  @unique
  name       String?
  givenName  String?
  familyName String?
  picture    String?

  //User settings
  //TimeZone from client
  timezone            String  @default("UTC")
  timezoneInitialized Boolean @default(false)

  // OAuth data
  scopes         String[]
  accessToken    String?   @db.Text // Can be long
  refreshToken   String?   @db.Text // Can be long
  tokenExpiresAt DateTime?

  // Feature flags (embedded, not separate table!)
  manualTracking    Boolean @default(true) // Always enabled
  automaticTracking Boolean @default(false) // Enabled when Gmail scope granted

  // Optional enhancements
  lastLoginAt DateTime?
  provider    String    @default("google")

  // Relations
  jobs Job[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Indexes for performance
  @@index([email])
  @@index([googleId])
}

model Job {
  id String @id @default(cuid())

  // Foreign key
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Job details
  company    String
  title      String
  status     JobStatus @default(APPLIED)
  appliedAt  DateTime  @db.Date // ← just the date, no time, no timezone
  receivedAt DateTime? // ← Gmail timestamp, is a point in time, store UTC

  // Tracking source
  source JobSource @default(MANUAL)

  // Gmail-specific data (only for automatic tracking)
  emailThreadId  String? // Gmail thread ID
  emailMessageId String?
  emailSubject   String?

  // Additional fields
  notes String? @db.Text
  url   String? // Job posting URL

  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? //soft delete, delete becomes an update default it will be null

  // Indexes
  @@unique([userId, emailMessageId]) //together are unique
  @@index([userId])
  @@index([status])
  @@index([source])
  @@index([emailThreadId])
  @@index([deletedAt])
}

enum JobStatus {
  APPLIED
  INTERVIEW_SCHEDULED
  INTERVIEW_COMPLETED
  OFFER
  REJECTED
  ACCEPTED
  WITHDRAWN
}

enum JobSource {
  MANUAL
  GMAIL_AUTO
}

